{
  "name": "chronos-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"ui,server\" --prefix-colors \"cyan,yellow\" \"vite\" \"cargo run -p chronos-server --manifest-path ../engine/Cargo.toml\"",
    "dev:ui": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "build:wasm": "cd ../engine && wasm-pack build chronos-wasm --target web --out-dir ../../ui/src/wasm",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "validate:worlds": "python ../scripts/validate_worlds.py"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.3",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-wasm": "^3.3.0",
    "vitest": "^4.1.9"
  }
}
