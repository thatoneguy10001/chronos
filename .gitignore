# Rust build artifacts — large, fully regenerated by cargo
/engine/target/

# wasm-pack output — regenerated by npm run build:wasm
/ui/src/wasm/

# Node / Vite
/ui/node_modules/
/ui/dist/

# Python
__pycache__/
*.pyc

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Local env overrides — not for version control
ui/.env.development.local
ui/.env.local

# Compiled JS artifacts emitted alongside .ts sources (tsc side-effects)
ui/src/**/*.js

# Ad-hoc dev screenshots (manual + verification captures, not assets)
ui/screenshot-*.png
ui/ss-*.png

# Playwright E2E run output — regenerated each run
ui/test-results/
ui/playwright-report/

# Local editor/agent config that shouldn't be shared
ui/.claude/
.claude/launch.json
