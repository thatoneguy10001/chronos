{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "chronos/class-template",
  "title": "ClassTemplate",
  "description": "Shared schema for both player classes and enemy classes.",
  "type": "object",
  "required": ["id", "name", "description", "base_stats", "abilities", "passives", "starting_equipment", "xp_reward"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "base_stats": {
      "type": "object",
      "description": "Starting numbers. `hp` seeds Health; every other key seeds the stat map. The canonical stats are documented below, but any additional integer key is allowed so a world can define its own stats (e.g. magic_power, movement_range).",
      "required": ["hp"],
      "additionalProperties": { "type": "integer" },
      "properties": {
        "hp":           { "type": "integer", "minimum": 1 },
        "attack":       { "type": "integer", "minimum": 0 },
        "defense":      { "type": "integer", "minimum": 0 },
        "intelligence": { "type": "integer", "minimum": 0 },
        "hit":          { "type": "integer", "minimum": 0 },
        "tech_attack":  { "type": "integer", "minimum": 0 },
        "evasion":      { "type": "integer", "minimum": 0 },
        "endurance":    { "type": "integer", "minimum": 0 },
        "luck":         { "type": "integer", "minimum": 0 },
        "agility":      { "type": "integer", "minimum": 0 }
      }
    },
    "abilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "base_damage"],
        "properties": {
          "id":              { "type": "string" },
          "name":            { "type": "string" },
          "description":     { "type": "string" },
          "base_damage":     { "type": "integer", "minimum": 0 },
          "hit_count":       { "type": "integer", "minimum": 1 },
          "applies_effect":  { "type": "string" },
          "effect_damage":   { "type": "integer", "minimum": 0 },
          "effect_duration": { "type": "integer", "minimum": 1 },
          "heal_amount":     { "type": "integer", "minimum": 0 },
          "heal_percent":    { "type": "number", "minimum": 0 },
          "cooldown":        { "type": "integer", "minimum": 1 },
          "targeting":       { "type": "string", "enum": ["caster", "target", "aoe"] }
        },
        "additionalProperties": false
      }
    },
    "passives": {
      "type": "array",
      "items": { "type": "string" }
    },
    "starting_equipment": {
      "type": "array",
      "items": { "type": "string" }
    },
    "xp_reward":   { "type": "integer", "minimum": 0 },
    "gold_reward": { "type": "integer", "minimum": 0 },
    "loot_table": {
      "type": "array",
      "description": "Items this class may drop when slain. Each entry is rolled independently.",
      "items": {
        "type": "object",
        "required": ["item_id", "chance"],
        "additionalProperties": false,
        "properties": {
          "item_id": { "type": "string" },
          "chance":  { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "level_up_gains": {
      "type": "object",
      "description": "Per-level stat gains. `hp` raises max HP; any other integer key raises that stat. Omit to use the engine default (ATK+1, DEF+1, HP+5).",
      "additionalProperties": { "type": "integer" },
      "properties": {
        "hp": { "type": "integer", "minimum": 0 }
      }
    },
    "tactics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["condition", "action"],
        "properties": {
          "condition": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type":      { "type": "string", "enum": ["always", "hp_below", "player_hp_above", "player_effect_absent"] },
              "threshold": { "type": "number" },
              "kind":      { "type": "string" }
            },
            "additionalProperties": false
          },
          "action": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type":       { "type": "string", "enum": ["basic_attack", "heavy_attack", "apply_effect", "use_ability"] },
              "multiplier": { "type": "number" },
              "kind":       { "type": "string" },
              "damage":     { "type": "integer" },
              "duration":   { "type": "integer" },
              "ability_id": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  }
}
