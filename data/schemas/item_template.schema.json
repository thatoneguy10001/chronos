{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "chronos/item-template",
  "title": "ItemTemplate",
  "type": "object",
  "required": ["id", "name", "description"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Globally unique snake_case identifier",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "name": {
      "type": "string",
      "description": "Human-readable display name"
    },
    "description": {
      "type": "string",
      "description": "Examination text shown on LOOK/EXAMINE"
    },
    "starting_room_id": {
      "type": ["string", "null"],
      "description": "Room where this item spawns at world init. Null = not placed."
    },
    "takeable": {
      "type": "boolean",
      "default": true
    },
    "attributes": {
      "type": "object",
      "description": "Arbitrary key-value data for game mechanics (weight, damage, etc.)",
      "additionalProperties": true
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Searchable labels (weapon, key, consumable, etc.)"
    }
  }
}
